# LLM
LLM_PROVIDER=openai                     # openai | anthropic | ollama
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=gpt-4o-mini                   # or claude-sonnet-4-6, llama3, etc.
LLM_TEMPERATURE=0.3
OLLAMA_BASE_URL=http://localhost:11434  # only used when LLM_PROVIDER=ollama
LLM_CONCURRENCY=5                      # parallel analyze calls; use 1-2 for Ollama

# Serper (Google SERP API — 2,500 free queries, no credit card)
# Sign up at https://serper.dev
SERPER_API_KEY=

# Database
DATABASE_URL=sqlite://./data/research.db

# Vector Store
VECTOR_STORE=chroma
CHROMA_URL=http://localhost:8000

# Scraping
SCRAPE_RATE_LIMIT_MS=2000
SCRAPE_USER_AGENT=ResearchAssistant/1.0
PUPPETEER_HEADLESS=true

# Notifications (optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Server
PORT=3000
NODE_ENV=development
