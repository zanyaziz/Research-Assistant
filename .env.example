# LLM
LLM_PROVIDER=openai                     # openai | anthropic | ollama
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=gpt-4o-mini                   # or claude-sonnet-4-6, llama3.2:3b, etc.
LLM_TEMPERATURE=0.3
LLM_CONCURRENCY=3                       # parallel analyze calls; use 1-2 for Ollama/local

# Ollama (only used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
# Context window — smaller is faster; 2048 fits all analysis prompts comfortably.
# Increase to 4096 only if synthesis output looks truncated.
OLLAMA_NUM_CTX=2048
# How long to keep the model loaded between runs. Prevents cold-reload penalty.
# '30m' is good for scheduled runs; '-1' keeps it loaded forever.
OLLAMA_KEEP_ALIVE=30m
#
# Recommended models by M1 RAM:
#   8 GB  → llama3.2:3b-instruct-q8_0   (fastest, good JSON reliability)
#   16 GB → llama3.1:8b-instruct-q4_K_M (better quality, still fast)
#   32 GB → qwen2.5:14b-instruct-q8_0   (best quality for structured output)
#
# System-level Ollama speed knobs (set in your shell or macOS launchd plist):
#   OLLAMA_NUM_PARALLEL=1        — don't parallelize within Ollama; let LLM_CONCURRENCY handle it
#   OLLAMA_MAX_LOADED_MODELS=1   — avoid model swapping if you have multiple models
#   OLLAMA_FLASH_ATTENTION=1     — enable Flash Attention (Ollama ≥ 0.3; major speedup on M1)
#   OLLAMA_NUM_THREADS=<N>       — pin CPU thread count (try physical core count, e.g. 8 for M1)

# Serper (Google SERP API — 2,500 free queries, no credit card)
# Sign up at https://serper.dev
SERPER_API_KEY=

# Database
DATABASE_URL=sqlite://./data/research.db

# Vector Store
VECTOR_STORE=chroma
CHROMA_URL=http://localhost:8000

# Scraping
SCRAPE_RATE_LIMIT_MS=2000
SCRAPE_USER_AGENT=ResearchAssistant/1.0
PUPPETEER_HEADLESS=true

# Notifications (optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Server
PORT=3000
NODE_ENV=development
